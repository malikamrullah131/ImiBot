# ImmiCare Chatbot - Environment Template
# Fill in your own keys below

# Gemini API Keys (comma separated)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# DeepSeek API Keys (comma separated)
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY_HERE"

# Mistral API Keys (comma separated)
MISTRAL_API_KEY="YOUR_MISTRAL_API_KEY_HERE"

# OpenRouter API Keys (comma separated)
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY_HERE"

# OpenClaw Configuration
OPENCLAW_API_KEY="YOUR_OPENROUTER_KEY_FOR_CLAUDE_REVIEWS"
OPENCLAW_BASE_URL="https://openrouter.ai/api/v1"
OPENCLAW_MODEL="anthropic/claude-3.5-sonnet"

# Neon/Postgres Database URL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google Spreadsheet Apps Script URL
GOOGLE_SCRIPT_WEB_APP_URL="https://script.google.com/macros/s/.../exec"

# Admin Dashboard Credentials
ADMIN_PASSWORD="ChooseYourPassword"

# Google Analytics 4 (GA4) Configuration
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
GA4_API_SECRET="YOUR_GA4_API_SECRET"
GA4_PROPERTY_ID="XXXXXXXXX"

# Google Cloud Service Account JSON (Minimized)
# Copy the structure of your service account JSON here
GOOGLE_APPLICATION_CREDENTIALS_JSON='{
  "type": "service_account",
  "project_id": "YOUR_PROJECT_ID",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "...",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "...",
  "universe_domain": "googleapis.com"
}'
