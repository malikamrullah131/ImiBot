{
  "version": 2,
  "public": true,
  "rewrites": [
    { "source": "/api/status", "destination": "/api/v-status" },
    { "source": "/api/logs", "destination": "/api/v-logs" },
    { "source": "/api/(.*)", "destination": "http://your-bot-public-url.com/api/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
